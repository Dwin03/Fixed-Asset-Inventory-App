<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dirtyWhite"
    tools:context=".Edit_Asset_Page">

    <ImageButton
        android:id="@+id/editAssetToAssetManager"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#00FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="?attr/homeAsUpIndicator" />

    <TextView
        android:id="@+id/editAssetLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="150dp"
        android:text="Edit Asset"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/editAssetNumber"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:paddingHorizontal="5dp"
        android:layout_marginTop="80dp"
        android:ems="10"
        android:inputType="text"
        android:hint="Type here . . . "
        android:textColor="@color/black"
        android:background="@drawable/textfiled_round_corners"
        app:layout_constraintEnd_toEndOf="@+id/editAssetLabel"
        app:layout_constraintStart_toStartOf="@+id/editAssetLabel"
        app:layout_constraintTop_toBottomOf="@+id/editAssetLabel" />

    <EditText
        android:id="@+id/editDescription"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:paddingHorizontal="5dp"
        android:layout_marginTop="60dp"
        android:ems="10"
        android:inputType="text"
        android:hint="Type here . . . "
        android:textColor="@color/black"
        android:background="@drawable/textfiled_round_corners"
        app:layout_constraintEnd_toEndOf="@+id/editAssetNumber"
        app:layout_constraintStart_toStartOf="@+id/editAssetNumber"
        app:layout_constraintTop_toBottomOf="@+id/editAssetNumber" />

    <EditText
        android:id="@+id/editLocation"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:paddingHorizontal="5dp"
        android:layout_marginTop="60dp"
        android:ems="10"
        android:inputType="text"
        android:hint="Type here . . . "
        android:textColor="@color/black"
        android:background="@drawable/textfiled_round_corners"
        app:layout_constraintEnd_toEndOf="@+id/editDescription"
        app:layout_constraintStart_toStartOf="@+id/editDescription"
        app:layout_constraintTop_toBottomOf="@+id/editDescription" />

    <EditText
        android:id="@+id/editRemarks"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:paddingHorizontal="5dp"
        android:layout_marginTop="60dp"
        android:ems="10"
        android:inputType="text"
        android:hint="Type here . . . "
        android:textColor="@color/black"
        android:background="@drawable/textfiled_round_corners"
        app:layout_constraintEnd_toEndOf="@+id/editLocation"
        app:layout_constraintStart_toStartOf="@+id/editLocation"
        app:layout_constraintTop_toBottomOf="@+id/editLocation" />

    <Button
        android:id="@+id/saveEditButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:text="Save"
        android:textColor="@color/white"
        android:backgroundTint="@color/darkBlue"
        app:layout_constraintEnd_toEndOf="@+id/editRemarks"
        app:layout_constraintStart_toStartOf="@+id/editRemarks"
        app:layout_constraintTop_toBottomOf="@+id/editRemarks" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asset Number"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@+id/editAssetNumber"
        app:layout_constraintStart_toStartOf="@+id/editAssetNumber" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@+id/editDescription"
        app:layout_constraintStart_toStartOf="@+id/editDescription" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Location"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@+id/editLocation"
        app:layout_constraintStart_toStartOf="@+id/editLocation" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remarks"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@+id/editRemarks"
        app:layout_constraintStart_toStartOf="@+id/editRemarks" />

</androidx.constraintlayout.widget.ConstraintLayout>